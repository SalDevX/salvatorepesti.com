#!/usr/bin/env python3
"""
bin/meta-controller — agent retry loop entry point
Generated by holography bootstrap.sh

Usage:
    bin/meta-controller --task "your task description"
    echo "task" | bin/meta-controller
    bin/meta-controller --task "task" --dry-run
"""
import argparse, json, os, re, subprocess, sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent
sys.path.insert(0, str(PROJECT_ROOT))
from tools.meta_controller import FailBlock, MetaController

def log_info(msg): print(f"[INFO] {msg}", flush=True)
def log_warn(msg): print(f"[WARN] {msg}", file=sys.stderr, flush=True)

def run_agent(task, patches, params):
    env = os.environ.copy()
    model = params.get("_model_override")
    if model == "human":
        log_warn("[meta-controller] human escalation required")
        return ""
    env_p = {k: v for k, v in params.items() if k != "_model_override"}
    if env_p: env["META_PARAM_PATCH"] = json.dumps(env_p)
    patched = task + ("\n" + "\n".join(f"[constraint] {p}" for p in patches) if patches else "")
    try:
        cmd = ["claude", "-p", "--dangerously-skip-permissions", patched]
        if model: cmd += ["--model", model]
        r = subprocess.run(cmd, capture_output=True, text=True, env=env, timeout=180, cwd=str(PROJECT_ROOT))
        return r.stdout if r.returncode == 0 else ""
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return ""

def run_validator(output):
    if not output: return False, "empty output", None
    has_diff = any(l.startswith("diff --git") for l in output.splitlines()) and "@@" in output
    if not has_diff: return False, "no-diff-output", None
    r = subprocess.run([sys.executable, str(PROJECT_ROOT / "tools" / "validator.py")],
        input=output, capture_output=True, text=True, cwd=str(PROJECT_ROOT), timeout=30)
    raw = (r.stdout + r.stderr).strip()
    passed = "STATUS: PASS" in raw and r.returncode == 0
    m = re.search(r"RETRY_WITH:\s*(\S+)", raw)
    retry = m.group(1) if m and m.group(1) not in ("none", "None") else None
    return passed, ("" if passed else raw), retry

def main():
    p = argparse.ArgumentParser()
    p.add_argument("--task", default="")
    p.add_argument("--fail-block", default="")
    p.add_argument("--dry-run", action="store_true")
    args = p.parse_args()
    task = args.task or (sys.stdin.read().strip() if not sys.stdin.isatty() else "")
    if not task:
        print("ERROR: provide task via --task or stdin", file=sys.stderr); return 2
    if args.dry_run:
        fb = FailBlock.from_text(args.fail_block or "FAIL:\n  category: parity\n  signal: dry run", attempt=1)
        mc = MetaController(task=task)
        for attempt in range(2, 4):
            plan = mc.build_retry_plan_for_attempt(fb, attempt)
            print(f"--- Attempt {attempt} ---\n{json.dumps(plan.as_dict(), indent=2)}\n")
        return 0
    fb = FailBlock.from_text(args.fail_block, attempt=1) if args.fail_block else None
    mc = MetaController(task=task, initial_fail_block=fb)
    result = mc.run(agent_runner=run_agent, validator=run_validator)
    if result["passed"]:
        log_info(f"PASS in {result['attempts']} attempt(s)"); return 0
    log_warn(f"ESCALATE after {result['attempts']} attempts — {result.get('report_path', '')}"); return 1

if __name__ == "__main__": sys.exit(main())
